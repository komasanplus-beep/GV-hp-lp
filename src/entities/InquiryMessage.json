{
  "name": "InquiryMessage",
  "type": "object",
  "properties": {
    "inquiry_id": {
      "type": "string",
      "description": "問い合わせID"
    },
    "sender_type": {
      "type": "string",
      "enum": ["user", "admin", "ai"],
      "description": "送信者タイプ"
    },
    "sender_id": {
      "type": "string",
      "description": "送信者ID"
    },
    "message": {
      "type": "string",
      "description": "メッセージ内容"
    },
    "is_official_reply": {
      "type": "boolean",
      "default": false,
      "description": "正式回答フラグ"
    }
  },
  "required": ["inquiry_id", "sender_type", "message"],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "inquiry_user_condition": "inquiry.user_id == {{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}
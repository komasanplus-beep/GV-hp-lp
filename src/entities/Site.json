{
  "name": "Site",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "site_name": {
      "type": "string"
    },
    "business_type": {
      "type": "string",
      "enum": [
        "hair_salon",
        "beauty_salon",
        "nail_salon",
        "esthetic",
        "relaxation",
        "gym",
        "clinic",
        "school",
        "other"
      ]
    },
    "template_type": {
      "type": "string",
      "enum": ["salon", "hotel", "default"],
      "default": "default",
      "description": "テンプレート種別（初期ページ生成時に使用）"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published"
      ],
      "default": "draft"
    },
    "enabled_features": {
      "type": "object",
      "description": "テンプレートから引き継いだ有効機能フラグ（補助用、最終判定は FeatureGrant / Subscription / PlanMaster を優先）",
      "properties": {
        "booking": {
          "type": "boolean",
          "default": false
        },
        "blog": {
          "type": "boolean",
          "default": false
        },
        "inquiry": {
          "type": "boolean",
          "default": true
        },
        "customer": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "owner_user_id": {
      "type": "string",
      "description": "サイト所有者のユーザーID"
    },
    "assigned_plan_code": {
      "type": "string",
      "description": "このサイトに割り当てられたプランコード（オプション、個別プラン的な使い方用）"
    },
    "navigation_config": {
      "type": "object",
      "description": "ヘッダーナビゲーション設定",
      "properties": {
        "logo_url": {
          "type": "string",
          "description": "ロゴURL"
        },
        "logo_image_url": {
          "type": "string",
          "description": "アップロード済みロゴ画像URL"
        },
        "logo_alt": {
          "type": "string",
          "description": "ロゴaltテキスト"
        },
        "site_name_text": {
          "type": "string",
          "description": "ヘッダーに表示するサイト名"
        },
        "booking_button_text": {
          "type": "string",
          "description": "予約ボタンのテキスト"
        },
        "booking_button_url": {
          "type": "string",
          "description": "予約ボタンのリンク"
        },
        "show_admin_link": {
          "type": "boolean",
          "default": false
        },
        "menu_items": {
          "type": "array",
          "description": "メニュー項目（手動設定分）",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "href": { "type": "string" },
              "sort_order": { "type": "number" },
              "is_visible": { "type": "boolean", "default": true }
            }
          }
        },
        "auto_menu_pages": {
          "type": "array",
          "description": "ページ自動連動メニュー設定",
          "items": {
            "type": "object",
            "properties": {
              "page_id": { "type": "string", "description": "SitePage ID" },
              "show_in_header": { "type": "boolean", "default": true },
              "label_override": { "type": "string", "description": "ラベル上書き（空白時はページタイトル使用）" },
              "sort_order": { "type": "number", "default": 0 }
            }
          }
        },
        "social_links": {
          "type": "array",
          "description": "SNSリンク（ヘッダー用）",
          "items": {
            "type": "object",
            "properties": {
              "platform": { "type": "string", "enum": ["x", "threads", "instagram", "facebook", "line", "linkedin", "note", "tiktok"] },
              "url": { "type": "string" },
              "show_in_header": { "type": "boolean", "default": false },
              "show_in_footer": { "type": "boolean", "default": false },
              "open_new_tab": { "type": "boolean", "default": true },
              "sort_order": { "type": "number", "default": 0 }
            }
          }
        }
      }
    },
    "footer_config": {
      "type": "object",
      "description": "フッター設定",
      "properties": {
        "copyright_text": {
          "type": "string",
          "description": "著作権表記のカスタムテキスト"
        },
        "footer_links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "href": {
                "type": "string"
              },
              "sort_order": {
                "type": "number"
              }
            },
            "required": [
              "label",
              "href"
            ]
          },
          "description": "フッターのリンク項目"
        },
        "show_site_name": {
          "type": "boolean",
          "default": true,
          "description": "サイト名を表示するか"
        },
        "show_year": {
          "type": "boolean",
          "default": true,
          "description": "年号を表示するか"
        },
        "show_company_name": {
          "type": "boolean",
          "default": false,
          "description": "会社名/店舗名を表示するか"
        },
        "company_name": {
          "type": "string",
          "description": "会社名/店舗名"
        },
        "address": {
          "type": "string",
          "description": "住所"
        },
        "phone": {
          "type": "string",
          "description": "電話番号"
        },
        "email": {
          "type": "string",
          "description": "メールアドレス"
        },
        "business_hours": {
          "type": "string",
          "description": "営業時間"
        },
        "show_fixed_pages": {
          "type": "boolean",
          "default": true,
          "description": "固定ページ（プライバシーポリシー等）をフッターに表示するか"
        },
        "social_links": {
          "type": "array",
          "description": "SNSリンク（フッター用）",
          "items": {
            "type": "object",
            "properties": {
              "platform": { "type": "string", "enum": ["x", "threads", "instagram", "facebook", "line", "linkedin", "note", "tiktok"] },
              "url": { "type": "string" },
              "show_in_footer": { "type": "boolean", "default": true },
              "open_new_tab": { "type": "boolean", "default": true },
              "sort_order": { "type": "number", "default": 0 }
            }
          }
        }
      }
    },
    "seo_config": {
      "type": "object",
      "description": "SEO設定",
      "properties": {
        "meta_title": {
          "type": "string",
          "description": "ページタイトル（60文字以内推奨）"
        },
        "meta_description": {
          "type": "string",
          "description": "メタディスクリプション（160文字以内推奨）"
        },
        "og_image_url": {
          "type": "string",
          "description": "OGP画像URL"
        }
      }
    }
  },
  "required": [
    "user_id",
    "site_name"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}
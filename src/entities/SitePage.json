{
  "name": "SitePage",
  "type": "object",
  "properties": {
    "site_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "page_type": {
      "type": "string",
      "enum": [
        "home",
        "about",
        "menu",
        "staff",
        "gallery",
        "access",
        "contact",
        "custom"
      ]
    },
    "parent_page_id": {
      "type": "string",
      "description": "親ページID（階層構造）"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published"
      ],
      "default": "draft"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    },
    "use_common_contact": {
      "type": "boolean",
      "default": true,
      "description": "共通接触情報を使用するか（false時はカスタム設定を使用）"
    },
    "custom_contact": {
      "type": "object",
      "description": "ページ個別の接触情報（use_common_contact=falseの時のみ有効）",
      "properties": {
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "map_url": { "type": "string" }
      }
    },
    "use_common_contact": {
      "type": "boolean",
      "default": true,
      "description": "共通連絡先設定を使用するか"
    },
    "contact_override": {
      "type": "object",
      "description": "共通設定の上書き用連絡先情報",
      "properties": {
        "shop_name": {
          "type": "string",
          "description": "店舗名（上書き用）"
        },
        "address": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "map_embed_url": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "site_id",
    "title",
    "slug"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}
{
  "name": "PlanUsage",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ユーザーID"
    },
    "month_year": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$",
      "description": "計測月（YYYY-MM形式）"
    },
    "lp_count": {
      "type": "number",
      "default": 0,
      "description": "作成されたLP数"
    },
    "site_count": {
      "type": "number",
      "default": 0,
      "description": "作成されたサイト数"
    },
    "ai_used": {
      "type": "number",
      "default": 0,
      "description": "使用したAI生成回数"
    },
    "storage_used": {
      "type": "number",
      "default": 0,
      "description": "使用したストレージ（MB）"
    },
    "notes": {
      "type": "string",
      "description": "備考"
    }
  },
  "required": [
    "user_id",
    "month_year"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}
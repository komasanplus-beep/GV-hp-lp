{
  "name": "Article",
  "type": "object",
  "properties": {
    "site_id": {
      "type": "string",
      "description": "所属サイトID"
    },
    "title": {
      "type": "string",
      "description": "記事タイトル"
    },
    "slug": {
      "type": "string",
      "description": "URL用スラグ"
    },
    "excerpt": {
      "type": "string",
      "description": "記事抜粋"
    },
    "blocks": {
      "type": "array",
      "description": "ブロック構造（JSON配列）",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ブロックID（UUID）"
          },
          "type": {
            "type": "string",
            "enum": [
              "heading",
              "paragraph",
              "image",
              "list",
              "quote",
              "separator",
              "button",
              "code",
              "table"
            ],
            "description": "ブロック種類"
          },
          "level": {
            "type": "number",
            "description": "見出しレベル（H2=2, H3=3, H4=4）"
          },
          "content": {
            "type": "string",
            "description": "テキストコンテンツ"
          },
          "image_url": {
            "type": "string",
            "description": "画像URL"
          },
          "alt_text": {
            "type": "string",
            "description": "画像altテキスト"
          },
          "width": {
            "type": "number",
            "description": "画像幅（%）"
          },
          "align": {
            "type": "string",
            "enum": ["left", "center", "right"],
            "description": "画像配置"
          },
          "list_type": {
            "type": "string",
            "enum": ["ordered", "unordered"],
            "description": "リスト種類"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "リストアイテム"
          },
          "style": {
            "type": "object",
            "description": "スタイル設定",
            "properties": {
              "font_size": {
                "type": "string",
                "enum": ["sm", "base", "lg", "xl", "2xl"],
                "default": "base"
              },
              "bold": {
                "type": "boolean",
                "default": false
              },
              "italic": {
                "type": "boolean",
                "default": false
              },
              "color": {
                "type": "string",
                "description": "テキストカラー（hex）"
              },
              "line_height": {
                "type": "string",
                "enum": ["tight", "normal", "relaxed", "loose"],
                "default": "normal"
              }
            }
          }
        },
        "required": ["id", "type"]
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published"],
      "default": "draft",
      "description": "記事ステータス"
    },
    "category_id": {
      "type": "string",
      "description": "カテゴリID"
    },
    "tag_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "タグID配列"
    },
    "thumbnail_url": {
      "type": "string",
      "description": "サムネイル画像URL"
    },
    "seo_title": {
      "type": "string",
      "description": "SEOタイトル"
    },
    "seo_description": {
      "type": "string",
      "description": "メタディスクリプション"
    },
    "seo_keywords": {
      "type": "string",
      "description": "SEOキーワード"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "公開日時"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "トップ表示フラグ"
    },
    "generate_toc": {
      "type": "boolean",
      "default": true,
      "description": "目次生成フラグ"
    },
    "ai_generated": {
      "type": "boolean",
      "default": false,
      "description": "AI生成フラグ"
    },
    "ai_prompt": {
      "type": "string",
      "description": "AI生成時のプロンプト"
    }
  },
  "required": ["site_id", "title"],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}
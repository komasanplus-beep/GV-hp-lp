{
  "name": "InquiryAttachment",
  "type": "object",
  "properties": {
    "inquiry_message_id": {
      "type": "string",
      "description": "問い合わせメッセージID"
    },
    "file_name": {
      "type": "string",
      "description": "ファイル名"
    },
    "file_url": {
      "type": "string",
      "description": "ファイルURL"
    },
    "file_type": {
      "type": "string",
      "description": "ファイル種別"
    },
    "file_size": {
      "type": "number",
      "description": "ファイルサイズ（バイト）"
    }
  },
  "required": ["inquiry_message_id", "file_name", "file_url"],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "inquiry_user_condition": "inquiry.user_id == {{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}
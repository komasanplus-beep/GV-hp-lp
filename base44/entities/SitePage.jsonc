{
  "name": "SitePage",
  "type": "object",
  "properties": {
    "site_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "page_type": {
      "type": "string",
      "enum": [
        "home",
        "about",
        "menu",
        "staff",
        "gallery",
        "access",
        "contact",
        "custom"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published"
      ],
      "default": "draft"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "site_id",
    "title",
    "slug"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}